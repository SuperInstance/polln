{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strict": false,
    "noImplicitAny": false,
    "skipDefaultLibCheck": true
  },
  "include": [
    "src/cli/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/cli/__tests__",
    "src/api",
    "src/core"
  ]
}
