          "bytes_accessed_new": "W_activations + W_KV_cache (weights in metal)",
          "ai_formula_new": {
            "standard": "AI_standard = FLOPs / (Weight_bytes + Activation_bytes + KV_bytes)",
            "mask_locked": "AI_mask_locked = FLOPs / (Activation_bytes + KV_bytes)",
            "improvement_factor": "AI_mask_locked / AI_standard = (Weight_bytes + Other) / Other ≈ 10-100× higher"
          }
        },
