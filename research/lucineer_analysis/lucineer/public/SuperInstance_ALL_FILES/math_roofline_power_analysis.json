        "temperature_time_equation": {
          "thermal_model": {
            "equation": "C_θ × dT/dt = P - (T - T_a) / R_θ",
            "where": {
              "C_θ": "Thermal capacitance in J/°C",
              "T": "Temperature in °C",
              "P": "Power in W",
              "R_θ": "Thermal resistance in °C/W"
            }
          },
          "solution": {
            "general": "T(t) = T_a + P × R_θ × (1 - exp(-t/τ))",
            "time_constant": "τ = R_θ × C_θ",
            "steady_state": "T_ss = T_a + P × R_θ"
          }
        },
