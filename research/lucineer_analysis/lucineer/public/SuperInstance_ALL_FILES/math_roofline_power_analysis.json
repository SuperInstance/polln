    "PART_1_ROOFLINE_MODEL_DERIVATION": {
      "section_1_1_standard_roofline": {
        "title": "Standard Roofline Model",
        "theoretical_foundation": {
          "roofline_equation": {
            "attainable_performance": "P = min(Peak_FLOPS, BW × AI)",
            "where": {
              "Peak_FLOPS": "Maximum compute throughput in FLOPs/second",
              "BW": "Memory bandwidth in bytes/second",
              "AI": "Arithmetic Intensity = FLOPs / Bytes_transferred"
            }
          },
          "arithmetic_intensity_derivation": {
            "definition": "AI = Total_FLOPs / Total_Bytes_Accessed",
            "components": {
              "bytes_accessed": "W_weights + W_activations + W_KV_cache",
              "for_standard_inference": "AI = (2 × n_params × seq_len) / (n_params × bytes_per_weight + seq_len × activation_bytes)"
            },
            "interpretation": {
              "low_AI": "Memory-bound: Performance limited by memory bandwidth",
              "high_AI": "Compute-bound: Performance limited by compute throughput",
              "crossover_point": "AI_crossover = Peak_FLOPS / BW"
            }
          }
        },
        "platform_comparison": {
          "gpu_a100": {
            "peak_fp16_tflops": 312,
            "peak_int8_top": 624,
            "memory_bandwidth_tb_s": 2.039,
            "crossover_ai": {
              "fp16": "312 / 2.039 = 153.1 FLOPs/byte",
              "int8": "624 / 2.039 = 306.2 Ops/byte"
            },
            "typical_ai_for_llm": {
              "prefill_phase": "10-50 FLOPs/byte",
              "decode_phase": "1-10 FLOPs/byte",
              "classification": "MEMORY-BOUND for LLM inference"
            },
            "roofline_derivation": {
              "memory_bound_region": "P = BW × AI for AI < AI_crossover",
              "compute_bound_region": "P = Peak_FLOPS for AI ≥ AI_crossover",
              "llm_position": "In memory-bound region due to weight fetching"
            }
          },
          "tpu_v4": {
            "peak_bf16_tflops": 275,
            "memory_bandwidth_tb_s": 1.2,
            "crossover_ai": "275 / 1.2 = 229.2 FLOPs/byte",
            "weight_fetch_bottleneck": "Similar to GPU - memory bound for LLM inference"
          },
          "jetson_orin_nano": {
            "peak_int8_top": 67,
            "memory_bandwidth_gb_s": 102,
            "crossover_ai": "67 / 102 = 0.66 Ops/byte",
            "typical_llm_ai": "1-10 Ops/byte",
            "position": "COMPUTE-BOUND for smaller models, memory-bound for large LLMs",
            "power_tdp_w": 25,
            "efficiency_top_w": 2.68
          }
        }
      },

      "section_1_2_modified_roofline_mask_locked": {
