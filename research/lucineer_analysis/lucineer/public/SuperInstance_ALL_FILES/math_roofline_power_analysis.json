    "APPENDIX_MATHEMATICAL_DERIVATIONS": {
      "a1_roofline_crossover_derivation": {
        "problem": "Find the context length where memory becomes the bottleneck",
        "solution": [
          "T_compute = Peak_OPS / FLOPs_per_token",
          "T_memory = BW / KV_bytes_per_token",
          "At crossover: T_compute = T_memory",
          "Peak_OPS / FLOPs_per_token = BW / (kv_factor × ctx)",
          "ctx = (BW × FLOPs_per_token) / (Peak_OPS × kv_factor)",
          "For 100 GOPS, 17 GB/s, kv_factor = 24,576 bytes/token:",
          "ctx = (17×10^9 × 2.6×10^9) / (100×10^9 × 24,576) = 18,022 tokens"
        ]
      },
      "a2_thermal_time_constant_derivation": {
        "problem": "Derive the thermal time constant for the chip",
        "solution": [
          "Thermal mass = mass × specific_heat",
          "Silicon die: 0.117g × 0.7 J/gK = 0.082 J/K",
          "Package + PCB contribution: ~0.5 J/K (estimated)",
          "Total thermal capacitance C_θ = 0.582 J/K",
          "With heatsink R_θ = 30°C/W",
          "Time constant τ = R_θ × C_θ = 30 × 0.582 = 17.5 seconds"
        ]
      },
      "a3_energy_per_token_derivation": {
        "problem": "Calculate total energy per generated token",
        "solution": [
          "Compute energy: 2.6G ops × 22 pJ/op = 57.2 μJ",
          "KV cache read (LPDDR4): 50.3 MB × 100 pJ/B = 5.0 μJ",
          "Activation I/O: negligible",
          "Control overhead: ~5% of compute = 2.9 μJ",
          "Total: 57.2 + 5.0 + 2.9 = 65.1 μJ per token",
          "With hybrid SRAM: 57.2 + 0.5 + 2.9 = 60.6 μJ per token"
        ]
