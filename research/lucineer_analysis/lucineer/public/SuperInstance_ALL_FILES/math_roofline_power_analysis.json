          },
          "network_model": {
            "total_resistance": "R_θ_ja = R_θ_jc + R_θ_cs + R_θ_sa",
            "components": {
              "R_θ_jc": "Junction-to-case thermal resistance",
              "R_θ_cs": "Case-to-heatsink thermal resistance",
              "R_θ_sa": "Heatsink-to-ambient thermal resistance"
            }
          }
        },
        "pi_hat_form_factor_analysis": {
          "dimensions": {
            "length_mm": 65,
            "width_mm": 56,
            "max_height_mm": 12,
            "pcb_area_mm2": 3640,
