            },
            {
              "name": "SwiGLU",
              "formula": "SiLU(X @ W_gate) * (X @ W_up)",
              "multiplication_type": "REQUIRED - element-wise multiply",
              "optimization": "Quantize or approximate",
              "energy_fraction": "~5% of FFN energy"
            },
            {
              "name": "GELU",
              "formula": "x * Phi(x) where Phi is CDF",
              "multiplication_type": "REQUIRED",
              "optimization": "LUT-based with 256 entries",
              "energy_fraction": "~3% of FFN energy"
            }
          ]
