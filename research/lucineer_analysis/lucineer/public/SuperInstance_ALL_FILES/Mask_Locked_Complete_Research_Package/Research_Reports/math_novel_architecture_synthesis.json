      "section_1_operation_classification": {
        "title": "Complete Classification of LLM Inference Operations",

        "linear_operations": {
          "description": "Operations of form Y = WX + b where W is weight matrix",
          "can_be_mask_locked": true,
          "operations": [
            {
              "name": "Embedding Projection",
              "formula": "E = token_id @ W_embed",
              "matrix_size": "vocab_size × hidden_dim",
              "mask_lockable": "YES - lookup table encoded in metal",
              "multiplication_type": "Can be ternary/addition-only"
            },
            {
              "name": "Attention Q/K/V Projections",
              "formula": "Q = X @ W_q, K = X @ W_k, V = X @ W_v",
              "matrix_size": "hidden_dim × hidden_dim each",
              "mask_lockable": "YES",
              "multiplication_type": "Ternary → addition-only"
            },
            {
              "name": "Attention Output Projection",
              "formula": "O = Attention @ W_o",
              "mask_lockable": "YES",
              "multiplication_type": "Ternary → addition-only"
            },
            {
              "name": "FFN Up/Down Projections",
              "formula": "H = activation(X @ W_up) @ W_down",
              "mask_lockable": "YES",
              "multiplication_type": "Ternary → addition-only"
            }
          ],
          "total_parameters": "Accounts for ~95% of model parameters"
        },

        "attention_operations": {
          "description": "Attention mechanism core operations",
          "can_be_mask_locked": "PARTIALLY",
          "operations": [
            {
              "name": "QK^T Score Computation",
              "formula": "scores = Q @ K^T / sqrt(d_k)",
              "mask_lockable": "NO - dynamic matrices",
              "multiplication_type": "Dynamic multiplication required",
              "optimization": "Can use ternary Q/K → addition-based",
              "energy_fraction": "~10% of attention energy"
            },
            {
              "name": "Softmax",
              "formula": "weights = exp(scores) / sum(exp(scores))",
              "mask_lockable": "NO - runtime computed",
              "multiplication_type": "exp, division, division",
              "optimization": "Piecewise linear approximation, LUT-based",
              "energy_fraction": "~5% of attention energy"
            },
            {
              "name": "Attention-Value Multiplication",
              "formula": "output = weights @ V",
              "mask_lockable": "NO - dynamic weights",
              "multiplication_type": "Dynamic multiplication",
              "optimization": "Sparse attention, quantized values",
              "energy_fraction": "~15% of attention energy"
            }
          ]
        },

        "normalization_operations": {
          "description": "Layer normalization operations",
          "can_be_mask_locked": "PARTIALLY",
          "operations": [
            {
              "name": "Mean Computation",
              "formula": "mu = mean(X, dim=-1)",
              "multiplication_type": "NONE - pure addition",
              "optimizable": "Already optimal"
            },
            {
              "name": "Variance Computation",
              "formula": "sigma^2 = mean((X - mu)^2)",
              "multiplication_type": "REQUIRED - squaring",
              "optimization": "Approximate with running statistics",
              "energy_fraction": "~2% of layer energy"
            },
            {
              "name": "Normalization",
              "formula": "X_norm = (X - mu) / sigma",
              "multiplication_type": "REQUIRED - division by sigma",
              "optimization": "Precompute 1/sigma, multiply instead",
              "energy_fraction": "~3% of layer energy"
            },
            {
              "name": "Scale and Shift",
              "formula": "Y = gamma * X_norm + beta",
              "multiplication_type": "REQUIRED - gamma multiplication",
              "optimization": "Absorb into adjacent layer weights",
              "energy_fraction": "~2% of layer energy"
            }
          ]
        },

        "activation_operations": {
          "description": "Non-linear activation functions",
          "can_be_mask_locked": "NO",
          "operations": [
            {
              "name": "ReLU/ReLU²",
              "formula": "max(0, x) or max(0, x)²",
              "multiplication_type": "None for ReLU, squaring for ReLU²",
              "optimization": "Comparator + conditional for ReLU"
            },
            {
              "name": "SiLU/Swish",
              "formula": "x * sigmoid(x)",
              "multiplication_type": "REQUIRED",
              "optimization": "Piecewise linear approximation",
