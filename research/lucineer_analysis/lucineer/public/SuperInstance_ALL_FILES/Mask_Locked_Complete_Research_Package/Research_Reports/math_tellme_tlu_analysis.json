    "metadata": {
      "version": "1.0",
      "date": "2025-01-20",
      "purpose": "Complete mathematical derivation of TeLLMe Table-Lookup MatMul for Gate 0 reference",
      "source_paper": "arXiv:2510.15926 - TeLLMe v2",
      "key_results": {
        "0.73B_model": "25 tok/s at 4.8W on KV260 FPGA",
        "technique": "Table-Lookup MatMul (TLMM) eliminates DSP multipliers",
        "resources": "98K LUTs, 610 DSPs, 60 URAMs"
      }
    },

    "part_1_table_lookup_matmul_mathematics": {
      "section_1_ternary_multiplication_truth_table": {
        "fundamental_principle": {
          "statement": "For ternary weights w ∈ {-1, 0, +1} and arbitrary activation a, the product w × a is NOT a multiplication operation but a SELECTION operation",
          "mathematical_proof": {
            "case_w_equals_plus1": {
              "weight": "+1",
              "product": "+1 × a = +a",
              "operation": "PASS THROUGH (identity function)",
              "hardware": "Direct connection, 0 gates"
            },
            "case_w_equals_minus1": {
              "weight": "-1",
              "product": "-1 × a = -a",
              "operation": "NEGATE (two's complement)",
              "hardware": "NOT gates + add 1, or dedicated negator"
            },
            "case_w_equals_zero": {
              "weight": "0",
              "product": "0 × a = 0",
              "operation": "SKIP (no operation)",
              "hardware": "No connection, 0 gates, 0 power"
            }
          },
          "critical_insight": "Ternary multiplication is O(1) selection, not O(n²) multiplication. This is the foundational optimization of TLMM."
        },

        "truth_table_complete": {
          "description": "All possible products w × a for w ∈ {-1, 0, +1}",
          "table": [
            {"w": "+1", "a": "any", "product": "+a", "operation": "select positive"},
            {"w": "-1", "a": "any", "product": "-a", "operation": "select negative"},
            {"w": "0", "a": "any", "product": "0", "operation": "select zero"}
          ],
          "simplified_truth_table": {
            "input_bits": 2,
            "output_function": "f(w, a) = w × a ∈ {-a, 0, +a}",
            "encoding": {
              "w_encoding": {"00": "0", "01": "+1", "10": "-1", "11": "reserved"},
              "a_encoding": "N-bit signed integer (INT4, INT8, etc.)"
            }
          }
        },

        "selection_vs_multiplication": {
          "multiplication_cost": {
            "gate_count": "O(N²) gates for N-bit multiplication",
            "int8_multiplier": "~300-500 gates",
            "int4_multiplier": "~100-150 gates",
            "latency": "O(N) stages in carry-save or booth encoding"
          },
          "selection_cost": {
            "gate_count": "O(N) gates for selection/negation",
            "int8_selector": "~50-80 gates (adder-subtractor mux)",
            "int4_selector": "~25-40 gates",
            "latency": "O(1) - single mux + optional negate"
          },
          "savings_factor": {
            "int8": "6-10× fewer gates",
            "int4": "4-6× fewer gates",
            "latency_improvement": "3-5× faster"
          }
        }
      },

      "section_2_lookup_table_design": {
        "lut_entries_derivation": {
          "concept": "Instead of computing w × a, store all possible products in a lookup table",
          "entries_per_weight_value": {
            "description": "For each weight value, we need to store the product for all possible activations",
            "for_weight_plus1": "Products are {+a | a ∈ range} = same as activation range",
            "for_weight_minus1": "Products are {-a | a ∈ range} = negated activation range",
            "for_weight_zero": "Product is always 0 = single value"
          },

          "activation_range_analysis": {
            "INT8_activation": {
              "range": "-128 to +127",
              "distinct_values": 256,
              "lut_entries_per_weight": 256,
              "total_lut_entries": "3 × 256 = 768 entries",
              "entry_width": "8 bits (for product)",
              "total_lut_size_bits": "768 × 8 = 6,144 bits"
            },
            "INT4_activation": {
              "range": "-8 to +7",
              "distinct_values": 16,
              "lut_entries_per_weight": 16,
              "total_lut_entries": "3 × 16 = 48 entries",
              "entry_width": "4 bits",
              "total_lut_size_bits": "48 × 4 = 192 bits"
            },
            "UINT8_activation": {
              "range": "0 to 255",
              "distinct_values": 256,
              "lut_entries_per_weight": 256,
              "total_lut_entries": "768 entries",
              "entry_width": "9 bits (need extra bit for signed result)",
              "total_lut_size_bits": "768 × 9 = 6,912 bits"
            }
          },

          "optimization_zero_weight": {
            "observation": "For w=0, the product is always 0 regardless of activation",
            "optimized_entries": "2 × 256 = 512 entries (only store +1 and -1 cases)",
            "savings_percent": "33% reduction in LUT size",
            "implementation": "Detect w=0 early, output 0 directly"
          }
        },

        "optimal_lut_structure": {
          "design_1_direct_addressed": {
            "address_bits": "2 (weight) + N (activation bits) = N+2 bits",
            "for_int8": "10-bit address, 1024-entry LUT",
            "data_width": "N bits (same as activation)",
            "access_time": "1 LUT cycle",
            "fpga_implementation": "Single BRAM or distributed LUTs"
          },

          "design_2_mux_based": {
            "concept": "Use activation as mux select, weight as data source select",
            "structure": [
              "LUT_pos[activation] = +activation (identity)",
              "LUT_neg[activation] = -activation (negated)",
              "Output = MUX(weight, {LUT_pos, LUT_neg, 0})"
            ],
            "hardware": [
              "For INT8: Two 256×8 ROMs + 1 3:1 mux",
              "For INT4: Two 16×4 ROMs + 1 3:1 mux"
            ],
            "advantage": "Simpler routing, regular structure"
          },

          "design_3_adder_subtractor": {
            "concept": "No LUT at all - just conditional add/subtract",
            "structure": [
              "If w = +1: output = a (pass through)",
              "If w = -1: output = -a (two's complement negate)",
              "If w = 0: output = 0 (no operation)"
            ],
            "hardware": "Single N-bit adder-subtractor with enable",
            "advantage": "No memory needed, pure combinational",
            "fpga_lut_usage": "~8 LUTs per bit = 64 LUTs for INT8 (vs 768 LUTs for stored table)",
            "savings_vs_bruteforce": "12× more efficient"
          }
        },

        "address_encoding_scheme": {
          "ternary_weight_encoding": {
            "option_1_two_bit": {
              "encoding": {"00": "0", "01": "+1", "10": "-1", "11": "invalid"},
              "advantage": "2 bits minimum",
              "disadvantage": "Invalid state possible"
            },
            "option_2_one_hot": {
              "encoding": {"001": "0", "010": "+1", "100": "-1"},
              "advantage": "No invalid states, natural for control",
              "disadvantage": "3 bits, more routing"
            },
            "option_3_signed_magnitude": {
              "encoding": "1 bit sign + 1 bit magnitude",
              "formula": "w = sign × magnitude where sign ∈ {-1,+1}, magnitude ∈ {0,1}",
              "advantage": "Natural for negation control"
            }
          },

          "activation_addressing": {
            "unsigned_offset": "Add 128 to INT8 to get 0-255 address",
            "signed_direct": "Use two's complement directly as address",
            "absolute_value": "For sign-magnitude LUT, use |a| as address, sign(a) as separate bit"
          },

          "combined_address": {
            "format": "[weight_select_bits][activation_bits]",
            "int8_example": "weight[1:0] + activation[7:0] = 10-bit address",
            "int4_example": "weight[1:0] + activation[3:0] = 6-bit address"
          }
        }
      },

      "section_3_accumulation_after_lookup": {
        "standard_mac_operation": {
          "formula": "y = Σᵢ wᵢ × xᵢ for i = 1 to N",
          "per_iteration": "sum += w × a",
          "hardware": "Multiplier + Adder + Register"
        },

        "tlmm_accumulation": {
          "formula": "y = Σᵢ LUT[wᵢ][aᵢ] for i = 1 to N",
          "per_iteration": "sum += LUT[w][a]",
          "hardware": "LUT lookup + Adder + Register"
        },

        "optimized_accumulation": {
          "grouped_by_weight": {
            "concept": "Group products by weight value before accumulation",
            "formula": "y = Σ₊(aᵢ | wᵢ=+1) - Σ₋(aⱼ | wⱼ=-1)",
            "hardware": [
              "Accumulator_pos = Σ activations where w = +1",
              "Accumulator_neg = Σ activations where w = -1",
              "Output = Accumulator_pos - Accumulator_neg"
            ],
            "advantage": "Two adders, no conditional operations in inner loop"
          },

          "parallel_accumulation": {
            "concept": "Multiple accumulators for different weight groups",
            "structure": [
              "PE_+1: accumulates activations with w = +1",
              "PE_-1: accumulates activations with w = -1",
              "PE_0: skipped entirely"
            ],
            "throughput": "K activations per cycle with K parallel PEs"
          }
        },

        "accumulator_width_calculation": {
          "worst_case_analysis": {
            "scenario": "All N weights are +1 (or all -1), all activations at maximum value",
            "formula": "max_sum = N × max(|a|)",
            "example_int8_4096_weights": {
              "N": 4096,
              "max_activation": 127,
              "max_sum": "4096 × 127 = 520,192",
              "bits_needed": "⌈log₂(520,192)⌉ = 20 bits"
            },
            "example_int8_2048_weights": {
              "N": 2048,
              "max_sum": "2048 × 127 = 260,096",
              "bits_needed": "19 bits"
            }
          },

          "statistical_analysis": {
            "assumption": "Weights uniformly distributed in {-1, 0, +1}, activations bounded",
            "expected_sum": "E[y] = E[w] × E[a] × N = 0 (weights have zero mean)",
            "variance": "Var[y] = N × Var[w] × E[a²]",
            "var_w": "2/3 (for uniform ternary)",
            "int8_example": {
              "E[a²]": "≈ 5500 (typical INT8 activation variance)",
              "Var[y]": "N × (2/3) × 5500",
              "std_dev_for_N_4096": "sqrt(4096 × 0.67 × 5500) ≈ 3883",
              "3_sigma_range": "±11,649 → needs 15 bits for 99.7% coverage"
            },
            "practical_width": "16-18 bits sufficient for typical LLM workloads"
          },

          "layer_specific_requirements": {
            "attention_layer": {
              "head_dim": 64,
              "typical_accumulator_width": "16 bits (64 × 127 / 4 average)"
            },
            "mlp_layer": {
              "intermediate_size": 8192,
              "typical_accumulator_width": "20 bits"
            },
            "recommendation": "Use 20-bit accumulators for safety margin"
          }
        }
      }
    },

