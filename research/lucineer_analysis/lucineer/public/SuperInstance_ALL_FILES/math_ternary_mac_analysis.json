    "PART_1_TERNARY_WEIGHT_REPRESENTATION": {
      "section_1_bitnet_b158_encoding": {
        "title": "BitNet b1.58 Encoding Analysis",
        
        "theoretical_derivation": {
          "why_158_bits": {
            "mathematical_basis": "Ternary alphabet {−1, 0, +1} has 3 symbols",
            "information_content": "I = log₂(3) = 1.5849625 bits per trit",
            "formal_proof": [
              "Given alphabet Σ = {−1, 0, +1} with |Σ| = 3",
              "Information per symbol: I = log₂(|Σ|) = log₂(3)",
              "Using Taylor expansion: ln(3) = ln(2×(1+0.5)) = ln(2) + ln(1.5)",
              "ln(3) ≈ 0.6931 + 0.4055 = 1.0986",
              "log₂(3) = ln(3)/ln(2) = 1.0986/0.6931 ≈ 1.585",
              "Therefore: 1.58 bits per ternary weight"
            ]
          },
          
          "ternary_representation": {
            "encoding_scheme": {
              "two_bit_encoding": {
                "description": "Naive 2-bit encoding",
                "mapping": {"00": "-1", "01": "0", "10": "+1", "11": "unused"},
                "efficiency": "log₂(3)/2 = 79.25%",
                "waste": "25% of codes unused"
              },
              "optimal_encoding": {
                "description": "Huffman coding for ternary",
                "method": "Group weights to approach 1.58 bits average",
                "example": "For sequence w₁w₂...wₙ, use base-3 encoding",
                "formula": "Encode n trits in ⌈n×log₂(3)⌉ bits"
              }
            }
          }
        },

        "information_entropy_analysis": {
          "entropy_formula": {
            "definition": "H(X) = −Σᵢ p(xᵢ) log₂ p(xᵢ)",
            "for_uniform_ternary": {
              "distribution": "p(−1) = p(0) = p(+1) = 1/3",
              "entropy": "H = −3 × (1/3) × log₂(1/3) = log₂(3) = 1.585 bits",
              "interpretation": "Maximum entropy achieved with uniform distribution"
            },
            "for_bitnet_distribution": {
              "typical_distribution": "p(−1) ≈ 0.32, p(0) ≈ 0.36, p(+1) ≈ 0.32",
              "entropy_calculation": [
                "H = −[0.32×log₂(0.32) + 0.36×log₂(0.36) + 0.32×log₂(0.32)]",
                "H = −[0.32×(−1.64) + 0.36×(−1.47) + 0.32×(−1.64)]",
                "H = 0.525 + 0.529 + 0.525 = 1.579 bits"
              ],
              "insight": "Near-uniform distribution maximizes information content"
            }
          },
          
          "comparison_table": {
            "FP16": {
              "bits_per_weight": 16,
              "entropy": "16 bits (full floating point)",
              "information_ratio": "1.0×"
            },
            "INT8": {
              "bits_per_weight": 8,
              "entropy": "~7.5 bits (effective with clipping)",
              "information_ratio": "0.47×"
            },
            "INT4": {
              "bits_per_weight": 4,
              "entropy": "~3.8 bits (effective)",
              "information_ratio": "0.24×"
            },
            "Binary": {
              "bits_per_weight": 1,
              "entropy": "1.0 bits",
              "information_ratio": "0.063×"
            },
            "Ternary": {
              "bits_per_weight": "1.58 (theoretical), 2 (practical storage)",
              "entropy": "1.585 bits",
              "information_ratio": "0.099×",
              "remark": "Only 10% of FP16 information, yet matches accuracy"
            }
          }
        },

        "storage_savings_ratio": {
