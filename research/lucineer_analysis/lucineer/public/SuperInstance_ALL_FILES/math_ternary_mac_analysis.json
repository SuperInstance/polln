    "NOVEL_OPTIMIZATION_THEOREMS": {
      "theorem_1_ternary_reduction": {
        "statement": "For weight matrix W ∈ {−1, 0, +1}^(m×n) and input X ∈ ℤ^(n×k), the matrix multiplication Y = WX requires exactly |W₊| + |W₋| integer additions, where |W₊| and |W₋| are the counts of positive and negative weights respectively.",
        "proof": [
          "Y = WX = Σ_w∈{−1,0,+1} w × x where w×x is computed per element",
          "For w = +1: contributes 1 addition",
          "For w = −1: contributes 1 subtraction (negation + addition)",
          "For w = 0: contributes 0 operations",
          "Total additions = |{w : w = +1}| + |{w : w = −1}| = |W₊| + |W₋|",
          "QED"
        ]
      },
      
      "theorem_2_energy_optimal_encoding": {
        "statement": "Given a ternary weight distribution with probability p(w=0) > 0, the energy-optimal hardware encoding physically removes zero-weight connections, achieving energy proportional to (1−p₀) per layer.",
        "proof": [
          "Energy for non-zero weight = E_add (adder energy)",
          "Energy for zero weight = 0 (no connection, no switching)",
          "Total energy = (|W₊| + |W₋|) × E_add = n × (1−p₀) × E_add",
          "This is optimal: cannot compute with less than (|W₊| + |W₋|) additions",
          "QED"
        ]
      },
      
      "theorem_3_sparsity_compute_bound": {
        "statement": "A ternary inference system with weight sparsity s = |{w=0}|/|W| becomes compute-bound when arithmetic intensity AI > BW_peak/COMP_peak, where BW_peak excludes weight bandwidth.",
        "proof": [
          "AI = FLOPs / (Activation_bytes + KV_bytes)",
          "Weight_bytes = 0 (mask-locked)",
          "BW_required = (Activation_bytes + KV_bytes) × throughput",
          "When AI × BW_required > COMP_peak, system is compute-bound",
          "Substituting: AI > COMP_peak / BW_peak",
          "For typical values: AI > 250 GOPS / 10 GB/s = 25 FLOPs/byte",
          "Ternary AI ~ 5000 FLOPs/byte >> 25, therefore compute-bound",
          "QED"
        ]
      }
    },

