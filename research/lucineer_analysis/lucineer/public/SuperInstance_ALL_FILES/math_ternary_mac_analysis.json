        "softmax_approximation_without_multiplication": {
          "method_1_piecewise_linear": {
            "description": "Approximate exp(x) with linear segments",
            "formula": "exp(x) ≈ max(0, a_i × x + b_i) for x in [x_i, x_{i+1}]",
            "multiplication_free_version": {
              "observation": "a_i × x requires multiplication",
              "solution": "Use powers of 2 for a_i: a_i = 2^k",
              "result": "a_i × x = x << k (bit shift, not multiplication)"
            },
            "accuracy": "~1-2% error with 16 segments"
          },
          
          "method_2_integer_softmax": {
            "description": "Integer-only softmax using repeated subtraction",
            "algorithm": [
              "1. Compute max(x) and subtract from all (shifted softmax)",
              "2. Use integer exp LUT (256 entries for INT8 input)",
              "3. Sum using integer addition",
              "4. Normalize using integer division or LUT"
            ],
            "multiplication_count": "0 (using LUT and integer ops)"
