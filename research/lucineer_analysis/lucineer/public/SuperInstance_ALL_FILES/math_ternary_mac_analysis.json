          "method_3_log_softmax": {
            "description": "Compute in log domain to avoid exp",
            "formula": "log_softmax(x_i) = x_i - log(Σ exp(x_j))",
            "log_sum_exp_trick": [
              "log(Σexp(x_j)) = max(x) + log(Σexp(x_j - max(x)))",
              "The subtraction max(x) avoids overflow",
              "log(Σexp(x_j - max(x))) can use LUT"
            ],
            "hardware": "Log LUT + adder (no multiplier)"
          }
        },

