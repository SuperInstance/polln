      "section_3_quantization_mathematics": {
        "title": "Quantization Mathematics",
        
        "optimal_thresholds_derivation": {
          "problem_statement": "Convert FP32 weights w ∈ ℝ to ternary w̃ ∈ {−1, 0, +1}",
          
          "uniform_threshold": {
            "method": "Symmetric quantization around zero",
            "threshold": "γ = mean(|w|) or γ = max(|w|) × α",
            "quantization_function": "w̃ = RoundClip(w/γ, −1, +1)",
            "where": "RoundClip(x, min, max) = max(min, min(max, round(x)))",
            "optimal_gamma_derivation": [
              "Objective: Minimize MSE = E[(w − w̃×γ)²]",
              "For given weight distribution p(w),",
              "γ* = argmin_γ ∫ (w − sgn(w)×γ)² p(w) dw",
              "Taking derivative and setting to zero:",
              "∂/∂γ ∫ (w − sgn(w)×γ)² p(w) dw = 0",
              "γ* = E[|w|] for symmetric distributions"
            ]
          },
          
          "learned_thresholds": {
            "method": "Per-channel learned scale factors",
            "formulation": "During training, learn scale γ per output channel",
            "bitnet_approach": {
              "weight_quantization": "w̃ᵢ = RoundClip(wᵢ/γ, −1, +1)",
              "scale_factor": "γ = 1.0/mean(|w|) or learned",
              "dequantization": "y = (W̃ @ x) × γ × β",
              "where_β": "Output scale factor (also learned)"
            }
          }
        },

        "mse_analysis": {
          "uniform_vs_learned": {
            "uniform_threshold_mse": {
              "formula": "MSE_uniform = Var(w | |w| < γ) + E[(|w| − γ)² | |w| ≥ γ]",
              "typical_value": "~0.1-0.3 × Var(w) for well-trained networks"
            },
            "learned_threshold_mse": {
              "formula": "MSE_learned = E[(w − w̃×γ*)²] where γ* is optimized per-channel",
              "typical_value": "~0.05-0.15 × Var(w)",
              "improvement": "~2× better than uniform"
            }
          },
          
          "numerical_example": {
            "weight_distribution": "Normal(0, σ²) with σ = 0.02 (typical for trained LLM)",
            "uniform_quantization": {
              "threshold": "γ = 1.5 × σ = 0.03",
              "quantized_regions": {
                "w < −γ": "w̃ = −1",
                "|w| ≤ γ": "w̃ = 0", 
                "w > γ": "w̃ = +1"
              },
              "mse_calculation": [
                "MSE = 2 × ∫₀^γ w²p(w)dw + 2 × ∫_γ^∞ (w−γ)²p(w)dw",
                "For p(w) ~ N(0, σ²):",
                "MSE ≈ σ² × [2Φ(−γ/σ)(γ/σ)² + erf(γ/(σ√2)) − 2φ(γ/σ)(γ/σ)]",
                "With γ/σ = 1.5: MSE ≈ 0.12σ²"
              ]
            }
          }
        },

        "layer_sensitivity_analysis": {
          "methodology": "Analyze gradient magnitude and Hessian eigenvalues per layer",
          
          "sensitivity_ranking": {
            "most_sensitive": [
              "Embedding layer (vocabulary lookup)",
              "Output projection (logits)",
              "Layer normalization parameters"
            ],
            "moderately_sensitive": [
              "Attention Q/K projections (affects attention patterns)",
              "First layer weights (input distribution)"
            ],
            "least_sensitive": [
              "FFN intermediate layers",
              "Attention output projection",
              "Middle layers (deep networks)"
            ]
          },
          
          "quantitative_sensitivity": {
            "sensitivity_metric": "S = ||∇_w L||₂ / ||w||₂",
            "typical_values": {
              "embedding": "S ≈ 0.1-0.5 (high sensitivity)",
              "attention_qk": "S ≈ 0.05-0.2",
              "ffn": "S ≈ 0.01-0.1 (lower sensitivity)"
            },
            "implication": "Sensitive layers need more careful quantization or higher precision"
          }
        }
      }
