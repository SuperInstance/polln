    "PART_3_THEORETICAL_PERFORMANCE_BOUNDS": {
      "section_7_roofline_analysis": {
        "title": "Roofline Analysis for Ternary Inference",
        
        "arithmetic_intensity_derivation": {
          "definition": "AI = FLOPs / Bytes transferred",
          
          "standard_fp16": {
