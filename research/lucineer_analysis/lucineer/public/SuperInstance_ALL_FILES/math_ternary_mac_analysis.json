      "section_2_matrix_multiplication_transformation": {
        "title": "Matrix Multiplication Transformation",
        
        "standard_formulation": {
          "definition": "Y = WX + b",
          "dimensions": {
            "W": "m × n weight matrix",
            "X": "n × k input matrix (k = batch_size × seq_len)",
            "Y": "m × k output matrix",
            "b": "m × 1 bias vector"
          },
          "element_wise": "yᵢⱼ = Σₖ wᵢₖ × xₖⱼ + bᵢ",
          "total_operations": "m × n × k multiplications + m × n × k additions"
        },

        "ternary_transformation": {
          "theorem": {
            "statement": "When W ∈ {−1, 0, +1}^(m×n), the multiplication wᵢₖ × xₖⱼ reduces to conditional addition/subtraction",
            "proof": [
              "Case 1: wᵢₖ = +1",
              "  yᵢⱼ += xₖⱼ (direct addition)",
              "Case 2: wᵢₖ = −1", 
              "  yᵢⱼ += (−xₖⱼ) = yᵢⱼ − xₖⱼ (subtraction)",
              "Case 3: wᵢₖ = 0",
              "  yᵢⱼ += 0 (no operation, skip)",
              "QED: Multiplication eliminated in all cases"
            ]
          },
          
          "ternary_element_formula": {
            "formula": "yᵢⱼ = Σₖ sgn(wᵢₖ) × xₖⱼ where sgn(w) ∈ {−1, 0, +1}",
            "alternative_form": "yᵢⱼ = Σₖ∈Pᵢⱼ xₖⱼ − Σₖ∈Nᵢⱼ xₖⱼ",
            "where": {
              "Pᵢⱼ": "set of indices k where wᵢₖ = +1",
              "Nᵢⱼ": "set of indices k where wᵢₖ = −1"
            },
            "operation_count": "|Pᵢⱼ| additions + |Nᵢⱼ| subtractions + |Zᵢⱼ| skipped operations"
          },

          "flopp_reduction_derivation": {
            "standard_MAC": {
              "operation": "y = w × x + accumulator",
              "flops_per_mac": "1 multiply + 1 add = 2 FLOPs",
              "total_for_layer": "m × n × k × 2 FLOPs"
            },
            "ternary_MAC": {
              "operation": "y = sgn(w) × x + accumulator = (±x) + accumulator",
              "flops_per_mac": "1 conditional add/sub = 1 FLOP (multiplication eliminated)",
              "effective_flops": "Consider sparsity:",
              "calculation": [
                "If p(w=0) = 0.35, then 35% of operations are skipped",
                "Effective operations = 0.65 × n per output element",
                "Each operation is 1 FLOP (add or subtract)",
                "Total = 0.65 × m × n × k FLOPs"
              ]
            },
            "flop_reduction_ratio": {
              "without_sparsity": "2 FLOPs → 1 FLOP = 50% reduction",
              "with_35_percent_sparsity": "2 FLOPs → 0.65 FLOP = 67.5% reduction",
              "combined_savings": "~3× fewer effective FLOPs"
            }
          }
        },

        "numerical_example_bitnet_2b": {
