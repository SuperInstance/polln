      "section_10_bit_serial_processing": {
        "title": "Bit-Serial Processing",
        
        "derivation": {
          "concept": "Process inputs bit-by-bit instead of in parallel",
          "motivation": "Further simplify hardware at cost of latency",
          
          "int8_bit_serial": {
            "input_representation": "x = Σ_{b=0}^{7} x_b × 2^b where x_b ∈ {0, 1}",
            "ternary_weight_multiplication": [
              "y = w × x where w ∈ {−1, 0, +1}",
              "y = w × Σ_b x_b × 2^b",
              "y = Σ_b (w × x_b) × 2^b",
              "Since x_b ∈ {0, 1}: w × x_b = {0, w}",
              "Result: y = Σ_b (x_b ? w : 0) × 2^b"
            ],
            "operation": "8 iterations of: check bit, conditional add/sub, shift"
          }
        },

        "latency_vs_area_tradeoff": {
          "bit_parallel": {
