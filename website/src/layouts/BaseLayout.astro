---
import '../styles/global.css';
import { Navigation } from '../components/layout/Navigation';
import { Footer } from '../components/layout/Footer';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SuperInstance.AI - Spreadsheet AI That Learns. Turn spreadsheet repetition into reusable AI agents with POLLN technology." />

    <title>
      <slot name="title">SuperInstance.AI - Spreadsheet AI That Learns</slot>
    </title>

    <!-- Open Graph / Social Media Meta Tags -->
    <meta property="og:title" content="SuperInstance.AI - Spreadsheet AI That Learns" />
    <meta property="og:description" content="Turn spreadsheet repetition into reusable AI agents with POLLN technology." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://superinstance.ai" />
    <meta property="og:image" content="/og-image.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="SuperInstance.AI - Spreadsheet AI That Learns" />
    <meta name="twitter:description" content="Turn spreadsheet repetition into reusable AI agents with POLLN technology." />
    <meta name="twitter:image" content="/og-image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Preconnect to CDNs -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navigation />

    <main class="flex-grow">
      <slot />
    </main>

    <Footer />
  </body>
</html>